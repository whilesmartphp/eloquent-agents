{
  "name": "whilesmart/eloquent-agents",
  "description": "AI tool-calling foundation for Laravel: ready-made tools, an agent harness, and an extension API on top of Prism",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "authors": [
    {
      "name": "WhileSmart",
      "email": "engineering@whilesmart.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0|^12.0",
    "prism-php/prism": "^0.99.22|^0.100"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "nunomaduro/collision": "^8.0",
    "laravel/pint": "^1.0",
    "fakerphp/faker": "^1.24"
  },
  "autoload": {
    "psr-4": {
      "Whilesmart\\Agents\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "Workbench\\App\\": "workbench/app/",
      "Workbench\\Database\\Factories\\": "workbench/database/factories/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Whilesmart\\Agents\\AgentsServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/testbench package:test",
    "pint": "./vendor/bin/pint",
    "pint:test": "./vendor/bin/pint --test"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
